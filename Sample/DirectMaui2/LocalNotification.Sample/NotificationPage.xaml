<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalNotification.Sample.NotificationPage"
             Title="Tapped">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
          VerticalOptions="Center">
        <Label
                Grid.Row="0"
                HorizontalOptions="Center"
                Text="Notification Tapped Successfully" />

        <Label
                Grid.Row="1"
                x:Name="IdLabel"
                HorizontalOptions="Center"/>

        <Label
                Grid.Row="2"
                x:Name="MessageLabel"
                HorizontalOptions="Center"/>

        <Label
                Grid.Row="3"
                x:Name="TapCountLabel"
                HorizontalOptions="Center"/>

        <Button
                Grid.Row="4"
                Clicked="Button_Clicked"
                HorizontalOptions="Center"
                Text="Go Back" />
    </Grid>
</ContentPage>
